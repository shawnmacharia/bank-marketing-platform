# -------------------------------------------------
# PostgreSQL credentials (used by Airflow metadata DB
# and by your ingestion scripts)
# -------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow      # Airflow metadata DB name

# -------------------------------------------------
# Airflow UI admin user (you log in with these)
# -------------------------------------------------
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# -------------------------------------------------
# Fernet key – encrypts connections & passwords inside Airflow.
# Generate ONE with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# and paste the result below (no quotes).
# -------------------------------------------------
AIRFLOW_FERNET_KEY=YOUR_FERNET_KEY_HERE
